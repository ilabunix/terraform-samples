AWSTemplateFormatVersion: '2010-09-09'
Description: 'EC2 Image Builder Infrastructure for BloomReach'

Parameters:
  BaseAMIId:
    Type: String
    Description: 'Base AMI ID from nit_base_ami_name.txt'
    # You'll provide this when deploying

Resources:
  # Infrastructure Configuration
  InfrastructureConfiguration:
    Type: AWS::ImageBuilder::InfrastructureConfiguration
    Properties:
      Name: bloomreach-infrastructure
      InstanceTypes:
        - t3a.large
      InstanceProfileName: EC2ImageBuilderInstanceProfile
      SubnetId: subnet-06bd3c06adb1bedbq
      SecurityGroupIds:
        - sg-0b3cce454eec38ab1
      TerminateInstanceOnFailure: true

  # Distribution Configuration
  DistributionConfiguration:
    Type: AWS::ImageBuilder::DistributionConfiguration
    Properties:
      Name: bloomreach-distribution
      Distributions:
        - Region: us-east-2
          AmiDistributionConfiguration:
            Name: 'BLOOMREACH-{{ imagebuilder:buildDate }}'
            AmiTags:
              BuildDate: '{{ imagebuilder:buildDate }}'
              BuildVersion: '{{ imagebuilder:buildVersion }}'
              Application: BloomReach
            LaunchPermissionConfiguration:
              UserIds:
                - '175809624659'
                - '762649877014'
                - '609253628652'

  # Silver Authoring Recipe
  SilverAuthoringRecipe:
    Type: AWS::ImageBuilder::ImageRecipe
    Properties:
      Name: bloomreach-silver-authoring-recipe
      Version: 1.0.0
      ParentImage: !Ref BaseAMIId
      Components:
        - ComponentArn: !Sub 'arn:aws:imagebuilder:${AWS::Region}:${AWS::AccountId}:component/bloomreach-silver-authoring-setup/1.0.0'
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            DeleteOnTermination: true
            Encrypted: true
            KmsKeyId: 781c2c45-9b01-4cb3-a47c-073e610b8782
            VolumeSize: 100
            VolumeType: gp3
            Iops: 3000

  # Silver Authoring Pipeline
  SilverAuthoringPipeline:
    Type: AWS::ImageBuilder::ImagePipeline
    Properties:
      Name: bloomreach-silver-authoring-pipeline
      ImageRecipeArn: !GetAtt SilverAuthoringRecipe.Arn
      InfrastructureConfigurationArn: !GetAtt InfrastructureConfiguration.Arn
      DistributionConfigurationArn: !GetAtt DistributionConfiguration.Arn
      Status: ENABLED

  # Silver Delivery Recipe
  SilverDeliveryRecipe:
    Type: AWS::ImageBuilder::ImageRecipe
    Properties:
      Name: bloomreach-silver-delivery-recipe
      Version: 1.0.0
      ParentImage: !Ref BaseAMIId
      Components:
        - ComponentArn: !Sub 'arn:aws:imagebuilder:${AWS::Region}:${AWS::AccountId}:component/bloomreach-silver-delivery-setup/1.0.0'
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            DeleteOnTermination: true
            Encrypted: true
            KmsKeyId: 781c2c45-9b01-4cb3-a47c-073e610b8782
            VolumeSize: 100
            VolumeType: gp3
            Iops: 3000

  # Silver Delivery Pipeline
  SilverDeliveryPipeline:
    Type: AWS::ImageBuilder::ImagePipeline
    Properties:
      Name: bloomreach-silver-delivery-pipeline
      ImageRecipeArn: !GetAtt SilverDeliveryRecipe.Arn
      InfrastructureConfigurationArn: !GetAtt InfrastructureConfiguration.Arn
      DistributionConfigurationArn: !GetAtt DistributionConfiguration.Arn
      Status: ENABLED

  # Bronze pipelines will reference Silver AMIs - create after Silver AMIs exist

Outputs:
  SilverAuthoringPipelineArn:
    Value: !GetAtt SilverAuthoringPipeline.Arn
  SilverDeliveryPipelineArn:
    Value: !GetAtt SilverDeliveryPipeline.Arn
