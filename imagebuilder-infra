AWSTemplateFormatVersion: '2010-09-09'
Description: 'EC2 Image Builder Infrastructure for BloomReach - Only Bronze AMIs Shared'

Parameters:
  BaseAMIId:
    Type: String
    Description: 'Base AMI ID from nit_base_ami_name.txt'

Resources:
  # ========================================
  # INFRASTRUCTURE CONFIGURATIONS
  # ========================================
  
  InfrastructureConfigurationAuthoring:
    Type: AWS::ImageBuilder::InfrastructureConfiguration
    Properties:
      Name: bloomreach-infrastructure-authoring
      InstanceTypes:
        - t3a.large
      InstanceProfileName: bloomreach-authoring-ec2-role
      SubnetId: subnet-06bd3c06adb1bedbq
      SecurityGroupIds:
        - sg-0b3cce454eec38ab1
      TerminateInstanceOnFailure: true
      Logging:
        S3Logs:
          S3BucketName: !Ref LogBucket
          S3KeyPrefix: imagebuilder-logs/authoring/

  InfrastructureConfigurationDelivery:
    Type: AWS::ImageBuilder::InfrastructureConfiguration
    Properties:
      Name: bloomreach-infrastructure-delivery
      InstanceTypes:
        - t3a.large
      InstanceProfileName: bloomreach-delivery-ec2-role
      SubnetId: subnet-0fa9d3cc9cfa30193
      SecurityGroupIds:
        - sg-0a2f22a4187db3b66
      TerminateInstanceOnFailure: true
      Logging:
        S3Logs:
          S3BucketName: !Ref LogBucket
          S3KeyPrefix: imagebuilder-logs/delivery/

  # ========================================
  # S3 BUCKET FOR LOGS
  # ========================================
  
  LogBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName: !Sub 'bloomreach-imagebuilder-logs-${AWS::AccountId}'
      VersioningConfiguration:
        Status: Enabled
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: AES256
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true

  # ========================================
  # DISTRIBUTION CONFIGURATIONS
  # ========================================
  
  # Silver Authoring - NOT SHARED
  DistributionConfigurationSilverAuthoring:
    Type: AWS::ImageBuilder::DistributionConfiguration
    Properties:
      Name: bloomreach-distribution-silver-authoring
      Distributions:
        - Region: us-east-2
          AmiDistributionConfiguration:
            Name: 'BLOOMREACH-SILVER-AUTHORING-{{ imagebuilder:buildDate }}'
            AmiTags:
              Tier: Silver
              Type: Authoring
              BuildDate: '{{ imagebuilder:buildDate }}'

  # Silver Delivery - NOT SHARED
  DistributionConfigurationSilverDelivery:
    Type: AWS::ImageBuilder::DistributionConfiguration
    Properties:
      Name: bloomreach-distribution-silver-delivery
      Distributions:
        - Region: us-east-2
          AmiDistributionConfiguration:
            Name: 'BLOOMREACH-SILVER-DELIVERY-{{ imagebuilder:buildDate }}'
            AmiTags:
              Tier: Silver
              Type: Delivery
              BuildDate: '{{ imagebuilder:buildDate }}'

  # Bronze Authoring - SHARED TO TEST/QA/PROD
  DistributionConfigurationBronzeAuthoring:
    Type: AWS::ImageBuilder::DistributionConfiguration
    Properties:
      Name: bloomreach-distribution-bronze-authoring
      Distributions:
        - Region: us-east-2
          AmiDistributionConfiguration:
            Name: 'bloomreach-authoring-{{ imagebuilder:buildDate | date "MMddyy" }}.1'
            AmiTags:
              Tier: Bronze
              Type: Authoring
              BuildDate: '{{ imagebuilder:buildDate }}'
            LaunchPermissionConfiguration:
              UserIds:
                - '175809624659'
                - '762649877014'
                - '609253628652'

  # Bronze Delivery - SHARED TO TEST/QA/PROD
  DistributionConfigurationBronzeDelivery:
    Type: AWS::ImageBuilder::DistributionConfiguration
    Properties:
      Name: bloomreach-distribution-bronze-delivery
      Distributions:
        - Region: us-east-2
          AmiDistributionConfiguration:
            Name: 'bloomreach-delivery-{{ imagebuilder:buildDate | date "MMddyy" }}.1'
            AmiTags:
              Tier: Bronze
              Type: Delivery
              BuildDate: '{{ imagebuilder:buildDate }}'
            LaunchPermissionConfiguration:
              UserIds:
                - '175809624659'
                - '762649877014'
                - '609253628652'

  # ========================================
  # SILVER AUTHORING
  # ========================================
  
  SilverAuthoringRecipe:
    Type: AWS::ImageBuilder::ImageRecipe
    Properties:
      Name: bloomreach-silver-authoring-recipe
      Version: 1.0.0
      ParentImage: !Ref BaseAMIId
      Components:
        - ComponentArn: !Sub 'arn:aws:imagebuilder:${AWS::Region}:${AWS::AccountId}:component/bloomreach-silver-authoring-setup/1.0.0'
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            DeleteOnTermination: true
            Encrypted: true
            KmsKeyId: 781c2c45-9b01-4cb3-a47c-073e610b8782
            VolumeSize: 100
            VolumeType: gp3
            Iops: 3000

  SilverAuthoringPipeline:
    Type: AWS::ImageBuilder::ImagePipeline
    Properties:
      Name: bloomreach-silver-authoring-pipeline
      ImageRecipeArn: !GetAtt SilverAuthoringRecipe.Arn
      InfrastructureConfigurationArn: !GetAtt InfrastructureConfigurationAuthoring.Arn
      DistributionConfigurationArn: !GetAtt DistributionConfigurationSilverAuthoring.Arn
      Status: ENABLED

  # ========================================
  # SILVER DELIVERY
  # ========================================
  
  SilverDeliveryRecipe:
    Type: AWS::ImageBuilder::ImageRecipe
    Properties:
      Name: bloomreach-silver-delivery-recipe
      Version: 1.0.0
      ParentImage: !Ref BaseAMIId
      Components:
        - ComponentArn: !Sub 'arn:aws:imagebuilder:${AWS::Region}:${AWS::AccountId}:component/bloomreach-silver-delivery-setup/1.0.0'
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            DeleteOnTermination: true
            Encrypted: true
            KmsKeyId: 781c2c45-9b01-4cb3-a47c-073e610b8782
            VolumeSize: 100
            VolumeType: gp3
            Iops: 3000

  SilverDeliveryPipeline:
    Type: AWS::ImageBuilder::ImagePipeline
    Properties:
      Name: bloomreach-silver-delivery-pipeline
      ImageRecipeArn: !GetAtt SilverDeliveryRecipe.Arn
      InfrastructureConfigurationArn: !GetAtt InfrastructureConfigurationDelivery.Arn
      DistributionConfigurationArn: !GetAtt DistributionConfigurationSilverDelivery.Arn
      Status: ENABLED

  # ========================================
  # BRONZE AUTHORING
  # ========================================
  
  BronzeAuthoringRecipe:
    Type: AWS::ImageBuilder::ImageRecipe
    Properties:
      Name: bloomreach-bronze-authoring-recipe
      Version: 1.0.0
      ParentImage: !Ref BaseAMIId  # Update later to Silver AMI
      Components:
        - ComponentArn: !Sub 'arn:aws:imagebuilder:${AWS::Region}:${AWS::AccountId}:component/bloomreach-bronze-authoring-setup/1.0.0'
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            DeleteOnTermination: true
            Encrypted: true
            KmsKeyId: 781c2c45-9b01-4cb3-a47c-073e610b8782
            VolumeSize: 100
            VolumeType: gp3
            Iops: 3000

  BronzeAuthoringPipeline:
    Type: AWS::ImageBuilder::ImagePipeline
    Properties:
      Name: bloomreach-bronze-authoring-pipeline
      ImageRecipeArn: !GetAtt BronzeAuthoringRecipe.Arn
      InfrastructureConfigurationArn: !GetAtt InfrastructureConfigurationAuthoring.Arn
      DistributionConfigurationArn: !GetAtt DistributionConfigurationBronzeAuthoring.Arn
      Status: DISABLED

  # ========================================
  # BRONZE DELIVERY
  # ========================================
  
  BronzeDeliveryRecipe:
    Type: AWS::ImageBuilder::ImageRecipe
    Properties:
      Name: bloomreach-bronze-delivery-recipe
      Version: 1.0.0
      ParentImage: !Ref BaseAMIId  # Update later to Silver AMI
      Components:
        - ComponentArn: !Sub 'arn:aws:imagebuilder:${AWS::Region}:${AWS::AccountId}:component/bloomreach-bronze-delivery-setup/1.0.0'
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            DeleteOnTermination: true
            Encrypted: true
            KmsKeyId: 781c2c45-9b01-4cb3-a47c-073e610b8782
            VolumeSize: 100
            VolumeType: gp3
            Iops: 3000

  BronzeDeliveryPipeline:
    Type: AWS::ImageBuilder::ImagePipeline
    Properties:
      Name: bloomreach-bronze-delivery-pipeline
      ImageRecipeArn: !GetAtt BronzeDeliveryRecipe.Arn
      InfrastructureConfigurationArn: !GetAtt InfrastructureConfigurationDelivery.Arn
      DistributionConfigurationArn: !GetAtt DistributionConfigurationBronzeDelivery.Arn
      Status: DISABLED

Outputs:
  SilverAuthoringPipelineArn:
    Value: !GetAtt SilverAuthoringPipeline.Arn
  SilverDeliveryPipelineArn:
    Value: !GetAtt SilverDeliveryPipeline.Arn
  BronzeAuthoringPipelineArn:
    Value: !GetAtt BronzeAuthoringPipeline.Arn
  BronzeDeliveryPipelineArn:
    Value: !GetAtt BronzeDeliveryPipeline.Arn
  LogBucket:
    Value: !Ref LogBucket
