# Add secondary source to Bronze Authoring
aws codebuild update-project \
  --name bloomreach-ami-bronze-authoring \
  --secondary-sources '[
    {
      "type": "CODEPIPELINE",
      "sourceIdentifier": "SilverAuthoringOutput"
